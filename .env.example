# Ollama chat model: use the exact name from `ollama list` (e.g. after `ollama pull gemma4:e2b`).
OLLAMA_MODEL=gemma4:e2b
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Embedding model (Sentence Transformers, downloaded on first ingest)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Retrieval
RETRIEVAL_K=5
# How many user note chunks to retrieve (separate Chroma collection user_notes)
NOTES_RETRIEVAL_K=4

# Starter tiles written to static/suggestions.json (ingest.py only)
# Caps how many tiles appear in the UI; increase if SUGGESTION_PRIORITY lists many slugs.
SUGGESTION_TILES=12
# How to pick tiles: alphabetical (default) | priority | random
# SUGGESTION_STRATEGY=alphabetical
# For priority: comma-separated folder slugs (order = tile order), then rest alphabetically until SUGGESTION_TILES.
# Empty + MDN …/reference/headers → uses built-in “important header” list.
# SUGGESTION_PRIORITY=accept,authorization,content-type,cache-control,cookie
# SUGGESTION_RANDOM_SEED=42

# Ingest: "hf" = Hugging Face dataset, "mdn" = local clone of github.com/mdn/content
# INGEST_SOURCE=hf
# HF_DATASET_ID=m-ric/huggingface_doc

# MDN (when INGEST_SOURCE=mdn): path to repo root (folder that contains files/)
# MDN_CONTENT_ROOT=./mdn-content
# Only index markdown under this path (relative to MDN_CONTENT_ROOT). Empty = all of files/en-us
# e.g. https://github.com/mdn/content/tree/main/files/en-us/web/http/reference/headers
# MDN_PATH_PREFIX=files/en-us/web/http/reference/headers
# Cap pages for faster/smaller index (0 = index every .md under files/en-us)
# MDN_MAX_FILES=2500
# MDN_RANDOM_SEED=42
